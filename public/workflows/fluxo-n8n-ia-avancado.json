    {
      "parameters": {
        "jsCode": "// Espera receber o JSON exatamente como no exemplo enviado\nconst qaExamples = $input.first().json.prompt.qaExamples\n\n// Ordena pelos campos \"order\"\nqaExamples.sort((a, b) => a.order - b.order);\n\nlet output = \"## Exemplos de Perguntas e Respostas\\n\\n\";\n\nqaExamples.forEach((qa, index) => {\n  output += `### Exemplo ${index + 1}\\n\\n`;\n  output += `**Pergunta:** ${qa.question}\\n\\n`;\n  output += `**Resposta:** ${qa.answer.trim()}\\n\\n`;\n});\n\nreturn [\n  {\n    json: {\n      qa_formatted: output\n    }\n  }\n];\n"
      },
